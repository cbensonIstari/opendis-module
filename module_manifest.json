{
  "module_name": "@istari:opendis-module",
  "module_version": "1.2.0",
  "module_type": "function",
  "module_checksum": "hash",
  "module_display_name": "opendis DIS Protocol Module",
  "internal": false,
  "tool": "opendis",
  "tool_versions": [
    "1.0"
  ],
  "tool_display_name": "opendis (IEEE 1278.1 DIS Protocol)",
  "operating_systems": [
    "macOS 26"
  ],
  "agent_version": ">9.0.0",
  "authors": [
    {
      "name": "Istari Engineering",
      "email": "gandalf@istaridigital.com"
    }
  ],
  "dependencies": [],
  "dev_dependencies": [
    {
      "name": "Python",
      "version": ">=3.12,<3.13",
      "tool_type": "auxiliary_tool",
      "reason": "Required for building and running the module.",
      "url": "https://www.python.org/"
    },
    {
      "name": "opendis",
      "version": ">=1.0",
      "tool_type": "auxiliary_tool",
      "reason": "Python implementation of IEEE 1278.1 DIS protocol.",
      "url": "https://pypi.org/project/opendis/"
    }
  ],
  "functions": {
    "@istari:ParseDISStream": [
      {
        "entrypoint": "opendis_module",
        "run_command": "{entrypoint} ParseDISStream --input-file {input_file} --output-file {output_file} --temp-dir {temp_dir}",
        "function_schema": {
          "inputs": {
            "input_model": {
              "type": "user_model",
              "validation_types": [
                "@extension:dis",
                "@extension:bin"
              ],
              "optional": false
            }
          },
          "outputs": [
            {
              "name": "pdus_json",
              "type": "file",
              "required": true
            },
            {
              "name": "metadata",
              "type": "file",
              "required": true
            }
          ]
        },
        "operating_systems": [
          "macOS 26"
        ],
        "tool_versions": [
          "1.0"
        ]
      }
    ],
